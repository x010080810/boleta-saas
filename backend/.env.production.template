# ============================================
# Boleta SaaS — Configuracion de Produccion
# ============================================
# Copiar a .env y completar los valores

ENVIRONMENT=production

# --- Base de Datos (Railway PostgreSQL) ---
# Obtener de: Railway Dashboard > PostgreSQL plugin > DATABASE_URL
DATABASE_URL=postgresql+asyncpg://postgres:<password>@<host>:<port>/<database>

# --- Redis / Celery (Upstash) ---
# Crear DB gratis en https://console.upstash.com/ y copiar UPSTASH_REDIS_URL
REDIS_URL=rediss://default:<password>@<upstash-host>.upstash.io:6379

# --- Seguridad ---
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=genera_un_secret_key_seguro_aqui

# --- Frontend ---
# URL del frontend en Vercel (poner después del deploy)
FRONTEND_URL=https://tu-app.vercel.app

# --- Storage Local (/tmp es efimero en Railway) ---
UPLOAD_DIR=/tmp/uploads
OUTPUT_DIR=/tmp/output
BACKUP_DIR=/tmp/backups

# --- Supabase Storage (S3-compatible, opcional pero recomendado) ---
# Configurar bucket 'payslips' en Supabase Storage Dashboard
# Obtener credenciales en: Storage > Settings > S3 Connection
SUPABASE_S3_ENDPOINT=https://<project>.supabase.co/storage/v1/s3
SUPABASE_S3_ACCESS_KEY=<access_key>
SUPABASE_S3_SECRET_KEY=<secret_key>
SUPABASE_S3_REGION=sa-east-1
STORAGE_BUCKET=payslips
SUPABASE_S3_PUBLIC_URL=https://<project>.supabase.co/storage/v1/object/public/payslips

# --- SMTP del Sistema ---
# Usar App Password de Gmail (16 digitos) si tienes 2FA
SYSTEM_SMTP_HOST=smtp.gmail.com
SYSTEM_SMTP_PORT=587
SYSTEM_SMTP_USER=tu_correo@gmail.com
SYSTEM_SMTP_PASSWORD=tu_app_password_16_digitos
SYSTEM_SMTP_FROM_EMAIL=tu_correo@gmail.com
SYSTEM_SMTP_FROM_NAME=Boleta SaaS
